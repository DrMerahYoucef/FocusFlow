<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Foreground service for timer -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <!-- Do Not Disturb / Notification Policy access -->
    <uses-permission android:name="android.permission.ACCESS_NOTIFICATION_POLICY" />

    <!-- Post notifications (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Attribution Tags for AppOps Auditing -->
    <attribution
        android:tag="default"
        android:label="@string/app_name" />
    <attribution
        android:tag="focus_monitor"
        android:label="@string/app_name" />
    <attribution
        android:tag="media"
        android:label="@string/app_name" />
    <attribution
        android:tag="notifications"
        android:label="@string/app_name" />

    <!-- Exact alarm for timer precision -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />

    <!-- Wake lock to keep timer alive on screen off -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Vibration for session end -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Internet for radio streams -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Foreground service for background audio -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />

    <!-- Keep WiFi alive during streaming -->
    <uses-permission android:name="android.permission.CHANGE_WIFI_MULTICAST_STATE" />

    <!-- Read installed apps list -->
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES" />

    <!-- Usage stats — detect which app is in foreground (app launch blocking) -->
    <uses-permission android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />

    <!-- Draw overlay (focus reminder screen on top of blocked app) -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!-- Wallpaper setting -->
    <uses-permission android:name="android.permission.SET_WALLPAPER" />

    <application
        android:name=".FocusFlowApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MyApplication">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.MyApplication">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Foreground Timer Service -->
        <service
            android:name=".service.PomodoroTimerService"
            android:foregroundServiceType="specialUse"
            android:exported="false">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Pomodoro timer service to track focused sessions and break cycles" />
        </service>

        <!-- Notification listener (block notifications from specific apps) -->
        <service
            android:name=".service.FocusNotificationListenerService"
            android:exported="true"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>

        <!-- App monitor foreground service -->
        <service
            android:name=".service.AppMonitorService"
            android:foregroundServiceType="specialUse"
            android:exported="false">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Monitors app launch to protect users focus sessions" />
        </service>

        <!-- Media player service declaration -->
        <service
            android:name=".service.RadioPlayerService"
            android:foregroundServiceType="mediaPlayback"
            android:exported="true">
            <intent-filter>
                <action android:name="androidx.media3.session.MediaSessionService" />
                <action android:name="android.media.browse.MediaBrowserService" />
            </intent-filter>
        </service>

        <!-- Focus Overlay activity -->
        <activity
            android:name=".FocusOverlayActivity"
            android:exported="false"
            android:theme="@style/Theme.MyApplication"
            android:launchMode="singleTop" />

        <!-- Home Screen Widget Receiver -->
        <receiver
            android:name=".widget.ExamCountdownWidgetReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/exam_countdown_widget_info" />
        </receiver>
    </application>

</manifest>
