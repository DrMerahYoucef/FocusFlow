<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg"
    android:orientation="vertical"
    android:padding="16dp"
    android:gravity="center_vertical">

    <TextView
        android:id="@+id/widget_title_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🎯 NEXT EXAM"
        android:textColor="#8A94A6"
        android:textSize="11sp"
        android:textStyle="bold"
        android:letterSpacing="0.08" />

    <TextView
        android:id="@+id/widget_exam_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="No upcoming trials"
        android:textColor="#2D3142"
        android:textSize="15sp"
        android:textStyle="bold"
        android:maxLines="1"
        android:ellipsize="end" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/widget_days_left"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--"
            android:textColor="#6C63FF"
            android:textSize="36sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_label_days"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:text="days\nleft"
            android:textColor="#8A94A6"
            android:textSize="11sp"
            android:lineSpacingMultiplier="0.9" />
    </LinearLayout>

</LinearLayout>
